    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
