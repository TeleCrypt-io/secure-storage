# Front door for the throwaway MAS-delegated Synapse stack. Matches the
# shape of a real MSC3861 deployment (compatibility mode): the homeserver
# origin (this) serves everything EXCEPT the three Matrix C-S API endpoints
# that MAS's docs say must be proxied to it directly — MAS's compat resource
# handles those, Synapse no longer serves them once
# `matrix_authentication_service.enabled: true` is set.
# See https://element-hq.github.io/matrix-authentication-service/setup/homeserver.html
:8008 {
	@compat path /_matrix/client/*/login /_matrix/client/*/logout /_matrix/client/*/refresh
	handle @compat {
		reverse_proxy throwaway-mas:8080
	}
	handle {
		reverse_proxy throwaway-synapse:8008
	}
}
